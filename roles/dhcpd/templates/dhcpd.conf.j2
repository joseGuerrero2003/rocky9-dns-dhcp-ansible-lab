# Generated by Ansible

option domain-name "{{ dhcpd_domain_name }}";
option domain-name-servers {{ dhcpd_domain_name_servers }};

default-lease-time {{ dhcpd_default_lease_time }};
max-lease-time {{ dhcpd_max_lease_time }};

{% if dhcpd_authoritative %}authoritative;
{% endif %}

{% for subnet in dhcpd_subnets %}
subnet {{ subnet.network }} netmask {{ subnet.netmask }} {
  range {{ subnet.range_start }} {{ subnet.range_end }};
  option routers {{ subnet.routers | join(', ') }};
  option broadcast-address {{ subnet.broadcast }};
}
{% endfor %}

{% if dhcpd_hosts | length > 0 %}
# Fixed-address assignments
{% for host in dhcpd_hosts %}
host {{ host.name }} {
  hardware ethernet {{ host.mac }};
  fixed-address {{ host.ip }};
}
{% endfor %}
{% endif %}
