// Generated by Ansible
options {
    listen-on port 53 { {% for addr in dns_options.listen_on %}{{ addr }}; {% endfor %} };
    directory "{{ dns_named_conf_dir }}";
    allow-query { {% for q in dns_options.allow_query %}{{ q }}; {% endfor %} };
    recursion {{ 'yes' if dns_options.recursion else 'no' }};
{% if dns_forwarders | length > 0 %}
    forwarders {
{% for f in dns_forwarders %}        {{ f }};
{% endfor %}    };
{% endif %}
};

logging {
    category default { "stderr"; };
};

zone "{{ dns_zone_forward }}" IN {
    type master;
    file "{{ dns_zone_forward_file }}";
    allow-update { none; };
};

zone "{{ dns_zone_reverse }}.in-addr.arpa" IN {
    type master;
    file "{{ dns_zone_reverse_file }}";
    allow-update { none; };
};
