$TTL {{ dns_zone_ttl }}
@   IN  SOA  ns. {{ dns_zone_forward }}. (
        {{ dns_zone_serial }} ; serial
        3600       ; refresh
        900        ; retry
        604800     ; expire
        86400      ; minimum
)

@       IN  NS  ns.{{ dns_zone_forward }}.

{% for record in dns_records %}
{{ record.ip.split('.')[-1] }}    IN  PTR {{ record.name }}.{{ dns_zone_forward }}.
{% endfor %}
